---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { sortByPubDateDesc } from '../utils/sort';

const recentPosts = sortByPubDateDesc(await getCollection('blog')).slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Low Hanging Data</h1>
			<p class="audience-hook">For analysts, developers, and researchers who want their data work to land.</p>
			<p class="lead">
				Ask what the data already shows before reaching for complexity.
				Every analysis here starts with the simplest approach — and only goes further when it changes a conclusion.
			</p>

			<hr />

			<h2>The Principles</h2>
			<ul class="principles">
				<li>
					<strong>Concise</strong> — If you can't state the finding in one sentence, the analysis isn't done yet.
				</li>
				<li>
					<strong>Transparent</strong> — Sources, assumptions, and limitations stated plainly. If someone else can't verify the work, it isn't finished.
				</li>
				<li>
					<strong>Low Hanging Fruit First</strong> — Counts and averages before machine learning. Simple questions answered clearly beat complex models nobody trusts.
				</li>
			</ul>

			<hr />

			<h2>Start Here</h2>
			<p>Articles grouped by where you are in the workflow:</p>
			<ul class="topic-list">
				<li>
					<strong>Collect</strong> —
					<a href="/article/getting-started-with-data/">Getting Started with Data Collection</a>,
					<a href="/article/pulling-data-from-apis/">Pulling Data from REST APIs</a>,
					<a href="/article/working-with-websockets-and-streaming-data/">WebSockets &amp; Streaming Data</a>
				</li>
				<li>
					<strong>Clean</strong> —
					<a href="/article/working-with-csv-and-json/">CSV and JSON</a>,
					<a href="/article/data-cleaning-and-validation/">Data Cleaning and Validation</a>,
					<a href="/article/python-pandas-data-wrangling/">Python &amp; Pandas for Data Wrangling</a>
				</li>
				<li>
					<strong>Query</strong> —
					<a href="/article/organizing-data-with-sql/">Organizing Data with SQL</a>,
					<a href="/article/working-with-parquet-and-duckdb/">Parquet and DuckDB</a>,
					<a href="/article/duckdb-for-financial-analysis/">DuckDB for Financial Analysis</a>
				</li>
				<li>
					<strong>Visualize</strong> —
					<a href="/article/visualizing-data-with-python/">Visualizing Data with Python</a>
				</li>
				<li>
					<strong>Automate</strong> —
					<a href="/article/building-your-first-data-pipeline/">Building Your First Data Pipeline</a>,
					<a href="/article/scheduling-and-automating-pipelines/">Scheduling and Automating Pipelines</a>
				</li>
			</ul>
			<p>
				See also: <a href="/posts">Posts</a> — shorter project retrospectives and case studies
				(distinct from Articles, which are how-to guides).
				Includes <a href="/posts/stock-trader-project-writeup/">building a stock prediction pipeline</a>
				and <a href="/posts/bd-mpar-aws-device-downtime/">how BD used AWS to predict device failures</a>.
			</p>

			<hr />

			<div class="author-bio">
				<p>
					<strong>About the author:</strong> I'm a data engineer and analyst focused on practical, reproducible analysis.
					I write here to document techniques I use day-to-day — the kind that don't require a PhD or a distributed cluster to run.
					Questions or feedback? <a href="mailto:admin@lowhangingdata.com">admin@lowhangingdata.com</a>
				</p>
			</div>

			<hr />

			<h2>Latest Articles</h2>
			<ul class="post-grid">
				{
					recentPosts.map((post) => (
						<li>
							<a href={`/article/${post.id}/`}>
								{post.data.heroImage && (
									<img src={post.data.heroImage} alt="" width={720} height={360} />
								)}
								<h4 class="post-title">{post.data.title}</h4>
								<p class="post-desc">{post.data.description}</p>
								<p class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))
				}
			</ul>
			<p class="view-all"><a href="/article">View all articles →</a></p>

			<hr />

			<div class="rss-feed">
				<h2>RSS Feed</h2>
				<p>Subscribe to new articles via RSS.</p>
				<a class="rss-cta" href="/rss.xml">Follow via RSS →</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
<style>
	.audience-hook {
		font-size: 0.95em;
		font-weight: 600;
		color: var(--accent);
		margin: -0.5em 0 1em;
		letter-spacing: 0.01em;
	}
	.lead {
		font-size: 1.1em;
		color: rgb(var(--gray-dark));
	}
	.author-bio {
		background: rgba(var(--gray-light), 0.5);
		border-left: 4px solid var(--accent);
		padding: 0.75em 1em;
	}
	.author-bio p {
		margin: 0;
		font-size: 0.95em;
		color: rgb(var(--gray-dark));
	}
	.rss-feed {
		text-align: center;
		padding: 1.5em 1em;
		background: rgba(var(--gray-light), 0.4);
		border-radius: 8px;
	}
	.rss-feed h2 {
		margin-top: 0;
	}
	.rss-feed p {
		color: rgb(var(--gray-dark));
		margin-bottom: 1.25em;
	}
	.rss-cta {
		display: inline-block;
		background: var(--accent);
		color: white;
		padding: 0.6em 1.4em;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95em;
		transition: background 0.2s ease;
	}
	.rss-cta:hover {
		background: var(--accent-dark);
	}
	.principles {
		list-style: none;
		padding: 0;
	}
	.principles li {
		padding: 0.75em 1em;
		margin-bottom: 0.75em;
		border-left: 4px solid var(--accent);
		background: rgba(var(--gray-light), 0.5);
	}
	.topic-list {
		padding-left: 1.25em;
		line-height: 2;
	}
	hr {
		margin: 2em 0;
	}
	.post-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		list-style: none;
		padding: 0;
		margin: 1.5rem 0;
	}
	.post-grid li {
		width: calc(50% - 0.75rem);
	}
	.post-grid li a {
		display: block;
		text-decoration: none;
		border: 1px solid rgba(var(--gray-light), 1);
		border-radius: 8px;
		overflow: hidden;
		transition: box-shadow 0.2s ease;
	}
	.post-grid li a:hover {
		box-shadow: var(--box-shadow);
	}
	.post-grid img {
		width: 100%;
		height: 160px;
		object-fit: cover;
		display: block;
	}
	.post-title {
		margin: 0.75rem 1rem 0.25rem;
		color: rgb(var(--black));
		font-size: 1rem;
		line-height: 1.3;
	}
	.post-desc {
		margin: 0 1rem 0.5rem;
		font-size: 0.85rem;
		color: rgb(var(--gray));
		line-height: 1.4;
	}
	.post-date {
		margin: 0 1rem 0.75rem;
		font-size: 0.8rem;
		color: rgb(var(--gray));
	}
	.post-grid li a:hover .post-title {
		color: rgb(var(--accent));
	}
	.view-all {
		text-align: right;
		font-size: 0.95rem;
	}
	@media (max-width: 720px) {
		.post-grid li {
			width: 100%;
		}
	}
</style>
