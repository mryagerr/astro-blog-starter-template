---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import { sortByPubDateDesc } from '../../utils/sort';
import { getDifficultyLabel, getDifficultyClass } from '../../utils/difficultyBadge';
import { VALID_TAGS, TAG_LABELS, TAG_SLUGS, TAG_DESCRIPTIONS, SLUG_TO_TAG, type Tag } from '../../utils/contentSchema';

export async function getStaticPaths() {
	return VALID_TAGS.map((tag) => ({
		params: { slug: TAG_SLUGS[tag] },
		props: { tag },
	}));
}

interface Props { tag: Tag; }
const { tag } = Astro.props;
const slug = TAG_SLUGS[tag];
const label = TAG_LABELS[tag];
const description = TAG_DESCRIPTIONS[tag];

const allArticles = sortByPubDateDesc(await getCollection('blog'));
const posts = allArticles.filter((p) => (p.data.tags ?? []).includes(tag));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${label} Articles — ${SITE_TITLE}`}
			description={description}
		/>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Home</a>
				<span class="breadcrumb-sep" aria-hidden="true">›</span>
				<a href="/article/">Articles</a>
				<span class="breadcrumb-sep" aria-hidden="true">›</span>
				<span aria-current="page">{label}</span>
			</nav>

			<div class="page-header">
				<h1>{label}</h1>
				<!-- REVIEW: category intro -->
				<p class="page-intro">{description}</p>
				<p class="page-count">{posts.length} article{posts.length === 1 ? '' : 's'}</p>
			</div>

			<div class="category-nav">
				{VALID_TAGS.map((t) => (
					<a
						href={`/category/${TAG_SLUGS[t]}/`}
						class={`cat-chip${t === tag ? ' cat-chip--active' : ''}`}
						aria-current={t === tag ? 'page' : undefined}
					>
						{TAG_LABELS[t]}
					</a>
				))}
			</div>

			{posts.length > 0 ? (
				<ul class="post-grid">
					{posts.map((post, i) => (
						<li class={`post-card${i === 0 ? ' post-card--featured' : ''}`}>
							<a href={`/article/${post.id}/`} aria-label={post.data.title}>
								<div class="card-img-wrap">
									<img
										width={720}
										height={360}
										src={post.data.heroImage ?? '/blog-placeholder-1.png'}
										alt={post.data.title}
										loading="lazy"
										decoding="async"
										sizes={i === 0
											? "(max-width: 720px) calc(100vw - 3em), (max-width: 1100px) calc(100vw - 6em), 1040px"
											: "(max-width: 720px) calc(100vw - 3em), (max-width: 1100px) calc(50vw - 3em), 520px"
										}
									/>
								</div>
								<div class="card-body">
									<p class="card-date label">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h2 class="card-title">{post.data.title}</h2>
									<p class="card-desc">{post.data.description}</p>
									{post.data.difficulty && (
										<span class={getDifficultyClass(post.data.difficulty)}>
											{getDifficultyLabel(post.data.difficulty)}
										</span>
									)}
								</div>
							</a>
						</li>
					))}
				</ul>
			) : (
				<p class="empty">No articles in this category yet.</p>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 clamp(1.5rem, 5vw, 4rem) 4rem;
	}

	.breadcrumb {
		padding: 1.25rem 0 0;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--caption);
		display: flex;
		align-items: center;
		gap: 0.4rem;
		flex-wrap: wrap;
	}
	.breadcrumb a { color: var(--caption); text-decoration: none; }
	.breadcrumb a:hover { color: var(--accent); }
	.breadcrumb-sep { color: var(--rule); }

	.page-header {
		margin: 2rem 0 1.5rem;
	}

	.page-header h1 {
		margin: 0 0 0.5rem;
	}

	.page-intro {
		font-size: 1rem;
		color: var(--caption);
		max-width: 640px;
		line-height: 1.65;
		margin: 0 0 0.5rem;
	}

	.page-count {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--caption);
		margin: 0;
	}

	.category-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 2rem;
	}

	.cat-chip {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		padding: 0.35em 0.85em;
		border-radius: 999px;
		border: 1.5px solid var(--rule);
		background: transparent;
		color: var(--caption);
		text-decoration: none;
		transition: all 0.18s ease;
	}

	.cat-chip:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.cat-chip--active {
		background: var(--accent);
		color: #fff;
		border-color: var(--accent);
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.post-card--featured {
		grid-column: 1 / -1;
	}

	.post-card--featured .card-img-wrap img {
		height: 340px;
	}

	.post-card--featured .card-title {
		font-size: 1.6rem;
	}

	.post-card a {
		display: block;
		text-decoration: none;
		border: 1px solid var(--rule);
		border-radius: 8px;
		overflow: hidden;
		background: var(--paper);
		transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
		position: relative;
	}

	.post-card a::before {
		content: '';
		position: absolute;
		top: 0; left: 0; bottom: 0;
		width: 3px;
		background: var(--accent);
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 0.2s ease;
		z-index: 1;
	}

	.post-card a:hover {
		box-shadow: var(--box-shadow);
		border-color: var(--accent-muted);
		transform: translateY(-2px);
	}

	.post-card a:hover::before {
		transform: scaleY(1);
	}

	.card-img-wrap { overflow: hidden; }

	.post-card img {
		width: 100%;
		height: 180px;
		object-fit: cover;
		display: block;
		transition: transform 0.3s ease;
	}

	.post-card a:hover img {
		transform: scale(1.03);
	}

	.card-body {
		padding: 1rem 1.1rem 1.1rem;
	}

	.card-date {
		margin: 0 0 0.35rem;
		color: var(--caption);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.card-title {
		margin: 0 0 0.4rem;
		font-family: var(--font-display);
		font-size: 1.05rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.3;
		color: var(--ink);
		transition: color 0.15s ease;
	}

	.post-card a:hover .card-title {
		color: var(--accent);
	}

	.card-desc {
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		color: var(--caption);
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.difficulty-badge {
		display: inline-block;
		margin-top: 0.4rem;
		padding: 0.2em 0.65em;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 600;
		font-family: var(--font-mono);
		letter-spacing: 0.02em;
	}

	.difficulty-low  { background: #dcfce7; color: #166534; }
	.difficulty-high { background: #fef9c3; color: #854d0e; }

	.empty {
		color: var(--caption);
		font-style: italic;
		text-align: center;
		padding: 3rem 0;
	}

	@media (max-width: 720px) {
		.post-grid { grid-template-columns: 1fr; gap: 1rem; }
		.post-card--featured { grid-column: unset; }
		.post-card--featured .card-img-wrap img { height: 200px; }
		.post-card--featured .card-title { font-size: 1.2rem; }
	}

	@media (max-width: 480px) {
		main { padding: 0 0.75rem 3rem; }
		.post-grid { gap: 0.75rem; }
		.post-card--featured .card-img-wrap img { height: 160px; }
		.post-card img { height: 140px; }
		.card-body { padding: 0.75rem 0.9rem; }
	}
</style>
