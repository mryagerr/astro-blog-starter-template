---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Page Not Found — Low Hanging Data"
			description="The page you're looking for doesn't exist. Browse our articles on data collection, processing, and analysis."
		/>
		<meta name="robots" content="noindex,follow" />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<div class="not-found">
				<p class="code">404</p>
				<h1>Page not found</h1>
				<p class="message">The page you're looking for doesn't exist or has moved.</p>
				<nav class="links">
					<a href="/">Home</a>
					<a href="/article/">Articles</a>
					<a href="/search/">Search</a>
				</nav>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 3rem clamp(1rem, 5vw, 2rem);
	}

	.not-found {
		text-align: center;
		padding: 4rem 0;
	}

	.code {
		font-family: var(--font-mono);
		font-size: 5rem;
		font-weight: 700;
		color: var(--accent);
		margin: 0 0 0.25rem;
		line-height: 1;
	}

	h1 {
		font-family: var(--font-display);
		font-size: 2rem;
		margin: 0 0 1rem;
	}

	.message {
		color: var(--caption);
		font-size: 1.05rem;
		margin-bottom: 2rem;
	}

	.links {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.links a {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 0.55em 1.25em;
		border: 1.5px solid var(--accent);
		border-radius: 6px;
		color: var(--accent);
		text-decoration: none;
		transition: background 0.18s ease, color 0.18s ease;
	}

	.links a:hover {
		background: var(--accent);
		color: white;
	}
</style>
