---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<html lang="en">
	<head>
		<BaseHead title={`404 — ${SITE_TITLE}`} description="This page doesn't exist." />
		<style>
			main {
				text-align: center;
				padding: 4em 1em;
			}
			.code {
				font-size: 8rem;
				font-weight: 700;
				line-height: 1;
				color: var(--accent);
				margin: 0 0 0.25em;
			}
			h1 {
				font-size: 1.5rem;
				margin: 0 0 1em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<p class="code">404</p>
			<h1>Page not found</h1>
			<p>The page you're looking for doesn't exist or has been moved.</p>
			<a href="/">← Back home</a>
		</main>
		<Footer />
	</body>
</html>
