---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { sortByPubDateDesc } from '../../utils/sort';
import { calculateReadingTime, calculateWordCount } from '../../utils/readingTime';

export async function getStaticPaths() {
	const posts = await getCollection('posts');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'posts'>;

const post = Astro.props;
const { Content, headings } = await render(post);

const wordCount = calculateWordCount(post.body);
const readingTime = calculateReadingTime(post.body);

// Related posts: 3 most recent posts excluding current
const allPosts = sortByPubDateDesc(await getCollection('posts'));
const relatedPosts = allPosts
	.filter((p) => p.id !== post.id)
	.slice(0, 3)
	.map((p) => ({
		id: p.id,
		title: p.data.title,
		description: p.data.description,
		pubDate: p.data.pubDate,
		heroImage: p.data.heroImage,
		href: `/posts/${p.id}/`,
	}));
---

<BlogPost
	{...post.data}
	readingTime={readingTime}
	wordCount={wordCount}
	headings={headings}
	relatedPosts={relatedPosts}
	breadcrumb={{ href: '/posts/', label: 'Posts' }}
>
	<Content />
</BlogPost>
