---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import { sortByPubDateDesc } from '../../utils/sort';

const posts = sortByPubDateDesc(await getCollection('posts'));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Posts — ${SITE_TITLE}`} description="Opinions, observations, and project write-ups from Low Hanging Data." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Posts</h1>
				<p class="page-sub">Opinions, observations, and project write-ups. For technical how-to guides, see <a href="/article">Articles</a>.</p>
			</div>

			<ul class="post-list">
				{
					posts.map((post) => (
						<li class="post-card">
							<a href={`/posts/${post.id}/`}>
								<div class="card-meta">
									<span class="card-date label">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<h2 class="card-title">{post.data.title}</h2>
								<p class="card-desc">{post.data.description}</p>
								<span class="card-read-more">Read →</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
	}

	.page-header {
		margin-bottom: 2.5rem;
	}

	.page-header h1 {
		margin-bottom: 0.4rem;
	}

	.page-sub {
		color: var(--caption);
		font-size: 0.95rem;
		margin: 0;
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.post-card a {
		display: block;
		text-decoration: none;
		border: 1px solid var(--rule);
		border-radius: 8px;
		padding: 1.25rem 1.5rem;
		background: var(--paper);
		position: relative;
		transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
	}

	.post-card a::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		bottom: 0;
		width: 3px;
		background: var(--accent);
		border-radius: 8px 0 0 8px;
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 0.2s ease;
	}

	.post-card a:hover {
		box-shadow: var(--box-shadow);
		border-color: var(--accent-muted);
		transform: translateY(-2px);
		text-decoration: none;
	}

	.post-card a:hover::before {
		transform: scaleY(1);
	}

	.card-meta {
		margin-bottom: 0.4rem;
	}

	.card-date {
		color: var(--caption);
	}

	.card-title {
		margin: 0 0 0.4rem;
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.3;
		color: var(--ink);
		transition: color 0.15s ease;
	}

	.post-card a:hover .card-title {
		color: var(--accent);
	}

	.card-desc {
		margin: 0 0 0.75rem;
		font-size: 0.9rem;
		color: var(--caption);
		line-height: 1.55;
	}

	.card-read-more {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		color: var(--accent);
		text-transform: uppercase;
	}

	@media (max-width: 480px) {
		.post-card a {
			padding: 1rem 1.1rem;
		}
		.card-title {
			font-size: 1.1rem;
		}
	}
</style>
