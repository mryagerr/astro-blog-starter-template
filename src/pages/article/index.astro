---
export const prerender = true;

import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { sortByPubDateDesc } from '../../utils/sort';
import { getDifficultyLabel, getDifficultyClass } from '../../utils/difficultyBadge';
import { VALID_TAGS, TAG_LABELS, TAG_SLUGS, type Tag } from '../../utils/contentSchema';

const posts = sortByPubDateDesc(await getCollection('blog'));

// Count articles per tag
const tagCounts = new Map<Tag, number>();
for (const post of posts) {
	for (const tag of post.data.tags ?? []) {
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Articles — ${SITE_TITLE}`} description="Practical guides on data collection, processing, analysis, and visualization — organized by publish date." />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<div class="page-header">
				<h1>Articles</h1>
				<p class="page-sub">All guides, organized by publish date. Start with the <a href="/#start-here">Start Here</a> sequence if you're new.</p>
			</div>

			<div class="tag-filters" aria-label="Filter by topic">
				<a href="/article/" class="tag-btn active" data-tag="all">All ({posts.length})</a>
				{VALID_TAGS.filter(t => tagCounts.has(t)).map((tag) => (
					<a href={`/category/${TAG_SLUGS[tag]}/`} class="tag-btn" data-tag={tag}>{TAG_LABELS[tag]} ({tagCounts.get(tag)})</a>
				))}
			</div>

			<ul class="post-grid">
				{
					posts.map((post, i) => (
						<li class={`post-card${i === 0 ? ' post-card--featured' : ''}`} data-tags={(post.data.tags ?? []).join(',')}>
							<a href={`/article/${post.id}/`} aria-label={post.data.title}>
								<div class="card-img-wrap">
									<img
										width={720}
										height={360}
										src={post.data.heroImage ?? '/blog-placeholder-1.png'}
										alt={post.data.title}
										loading="lazy"
										decoding="async"
										sizes={i === 0
											? "(max-width: 720px) calc(100vw - 3em), (max-width: 1100px) calc(100vw - 6em), 1040px"
											: "(max-width: 720px) calc(100vw - 3em), (max-width: 1100px) calc(50vw - 3em), 520px"
										}
									/>
								</div>
								<div class="card-body">
									<p class="card-date label">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h4 class="card-title">{post.data.title}</h4>
									{(post.data.tags ?? []).length > 0 && (
										<div class="card-tags">
											{(post.data.tags ?? []).map((tag) => (
												<a
													href={`/category/${TAG_SLUGS[tag]}/`}
													class="card-tag"
													onclick="event.stopPropagation()"
												>
													{TAG_LABELS[tag]}
												</a>
											))}
										</div>
									)}
									{post.data.difficulty && (
										<span class={getDifficultyClass(post.data.difficulty)}>
											{getDifficultyLabel(post.data.difficulty)}
										</span>
									)}
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1100px;
	}

	.page-header {
		margin-bottom: 2.5rem;
	}

	.page-header h1 {
		margin-bottom: 0.4rem;
	}

	.page-sub {
		color: var(--caption);
		font-size: 0.95rem;
		margin: 0;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	/* Featured first card spans full width */
	.post-card--featured {
		grid-column: 1 / -1;
	}

	.post-card--featured .card-img-wrap img {
		height: 340px;
	}

	.post-card--featured .card-title {
		font-size: 1.6rem;
	}

	.post-card a {
		display: block;
		text-decoration: none;
		border: 1px solid var(--rule);
		border-radius: 8px;
		overflow: hidden;
		background: var(--paper);
		transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
		position: relative;
	}

	.post-card a::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		bottom: 0;
		width: 3px;
		background: var(--accent);
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 0.2s ease;
		z-index: 1;
	}

	.post-card a:hover {
		box-shadow: var(--box-shadow);
		border-color: var(--accent-muted);
		transform: translateY(-2px);
		text-decoration: none;
	}

	.post-card a:hover::before {
		transform: scaleY(1);
	}

	.card-img-wrap {
		overflow: hidden;
	}

	.post-card img {
		width: 100%;
		height: 180px;
		object-fit: cover;
		display: block;
		border-radius: 0;
		transition: transform 0.3s ease;
	}

	.post-card a:hover img {
		transform: scale(1.03);
	}

	.card-body {
		padding: 1rem 1.1rem 1.1rem;
	}

	.card-date {
		margin: 0 0 0.35rem;
		color: var(--caption);
	}

	.card-title {
		margin: 0 0 0.4rem;
		font-family: var(--font-display);
		font-size: 1.05rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.3;
		color: var(--ink);
		transition: color 0.15s ease;
	}

	.post-card a:hover .card-title {
		color: var(--accent);
	}

	.difficulty-badge {
		display: inline-block;
		margin-top: 0.4rem;
		padding: 0.2em 0.65em;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 600;
		font-family: var(--font-mono);
		letter-spacing: 0.02em;
	}

	.difficulty-low  { background: #dcfce7; color: #166534; }
	.difficulty-high { background: #fef9c3; color: #854d0e; }

	.tag-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 2rem;
	}

	.tag-btn {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		padding: 0.35em 0.85em;
		border-radius: 999px;
		border: 1.5px solid var(--rule);
		background: transparent;
		color: var(--caption);
		cursor: pointer;
		text-decoration: none;
		transition: all 0.18s ease;
	}

	.tag-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.tag-btn.active {
		background: var(--accent);
		color: #fff;
		border-color: var(--accent);
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		margin: 0.35rem 0 0.25rem;
	}

	.card-tag {
		font-family: var(--font-mono);
		font-size: 0.68rem;
		letter-spacing: 0.04em;
		padding: 0.15em 0.6em;
		border-radius: 999px;
		border: 1px solid var(--rule);
		color: var(--caption);
		text-decoration: none;
		transition: color 0.15s, border-color 0.15s;
	}

	.card-tag:hover {
		color: var(--accent);
		border-color: var(--accent);
	}

	.post-card[hidden] { display: none; }

	@media (max-width: 720px) {
		.post-grid { grid-template-columns: 1fr; gap: 1rem; }
		.post-card--featured { grid-column: unset; }
		.post-card--featured .card-img-wrap img { height: 200px; }
		.post-card--featured .card-title { font-size: 1.2rem; }
	}

	@media (max-width: 480px) {
		.post-grid { gap: 0.75rem; }
		.post-card--featured .card-img-wrap img { height: 160px; }
		.post-card img { height: 140px; }
		.card-body { padding: 0.75rem 0.9rem; }
	}
</style>

<script>
	// Progressive enhancement: intercept chip clicks for instant client-side filtering.
	// Without JS, chips navigate to /article/ or /category/{slug}/ as real links.
	const chips = document.querySelectorAll<HTMLAnchorElement>('.tag-btn');
	const cards = document.querySelectorAll<HTMLElement>('.post-card');

	chips.forEach((chip) => {
		chip.addEventListener('click', (e) => {
			e.preventDefault();
			const tag = chip.dataset.tag;
			chips.forEach((c) => c.classList.remove('active'));
			chip.classList.add('active');
			cards.forEach((card) => {
				if (tag === 'all') {
					card.hidden = false;
				} else {
					const tags = (card.dataset.tags ?? '').split(',');
					card.hidden = !tags.includes(tag!);
				}
			});
		});
	});
</script>
