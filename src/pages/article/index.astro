---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { sortByPubDateDesc } from '../../utils/sort';
import { getDifficultyLabel, getDifficultyClass } from '../../utils/difficultyBadge';

const posts = sortByPubDateDesc(await getCollection('blog'));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Articles — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Articles</h1>
				<p class="page-sub">All guides, organized by publish date. Start with the <a href="/#start-here">Start Here</a> sequence if you're new.</p>
			</div>

			<ul class="post-grid">
				{
					posts.map((post, i) => (
						<li class={`post-card${i === 0 ? ' post-card--featured' : ''}`}>
							<a href={`/article/${post.id}/`}>
								<div class="card-img-wrap">
									<img
										width={720}
										height={360}
										src={post.data.heroImage ?? '/blog-placeholder-1.svg'}
										alt=""
									/>
								</div>
								<div class="card-body">
									<p class="card-date label">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h4 class="card-title">{post.data.title}</h4>
									{post.data.difficulty && (
										<span class={getDifficultyClass(post.data.difficulty)}>
											{getDifficultyLabel(post.data.difficulty)}
										</span>
									)}
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1100px;
	}

	.page-header {
		margin-bottom: 2.5rem;
	}

	.page-header h1 {
		margin-bottom: 0.4rem;
	}

	.page-sub {
		color: var(--caption);
		font-size: 0.95rem;
		margin: 0;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	/* Featured first card spans full width */
	.post-card--featured {
		grid-column: 1 / -1;
	}

	.post-card--featured .card-img-wrap img {
		height: 340px;
	}

	.post-card--featured .card-title {
		font-size: 1.6rem;
	}

	.post-card a {
		display: block;
		text-decoration: none;
		border: 1px solid var(--rule);
		border-radius: 8px;
		overflow: hidden;
		background: var(--paper);
		transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
		position: relative;
	}

	.post-card a::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		bottom: 0;
		width: 3px;
		background: var(--accent);
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 0.2s ease;
		z-index: 1;
	}

	.post-card a:hover {
		box-shadow: var(--box-shadow);
		border-color: var(--accent-muted);
		transform: translateY(-2px);
		text-decoration: none;
	}

	.post-card a:hover::before {
		transform: scaleY(1);
	}

	.card-img-wrap {
		overflow: hidden;
	}

	.post-card img {
		width: 100%;
		height: 180px;
		object-fit: cover;
		display: block;
		border-radius: 0;
		transition: transform 0.3s ease;
	}

	.post-card a:hover img {
		transform: scale(1.03);
	}

	.card-body {
		padding: 1rem 1.1rem 1.1rem;
	}

	.card-date {
		margin: 0 0 0.35rem;
		color: var(--caption);
	}

	.card-title {
		margin: 0 0 0.4rem;
		font-family: var(--font-display);
		font-size: 1.05rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.3;
		color: var(--ink);
		transition: color 0.15s ease;
	}

	.post-card a:hover .card-title {
		color: var(--accent);
	}

	.difficulty-badge {
		display: inline-block;
		margin-top: 0.4rem;
		padding: 0.2em 0.65em;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 600;
		font-family: var(--font-mono);
		letter-spacing: 0.02em;
	}

	.difficulty-low  { background: #dcfce7; color: #166534; }
	.difficulty-high { background: #fef9c3; color: #854d0e; }

	@media (max-width: 720px) {
		.post-grid { grid-template-columns: 1fr; gap: 1rem; }
		.post-card--featured { grid-column: unset; }
		.post-card--featured .card-img-wrap img { height: 200px; }
		.post-card--featured .card-title { font-size: 1.2rem; }
	}

	@media (max-width: 480px) {
		.post-grid { gap: 0.75rem; }
		.post-card--featured .card-img-wrap img { height: 160px; }
		.post-card img { height: 140px; }
		.card-body { padding: 0.75rem 0.9rem; }
	}
</style>
