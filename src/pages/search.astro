---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

const query = (Astro.url.searchParams.get('q') || '').trim();
const queryLower = query.toLowerCase();

interface Result {
	title: string;
	description: string;
	url: string;
	pubDate: Date;
	type: 'Article' | 'Post';
}

let results: Result[] = [];
let searched = false;

if (queryLower) {
	searched = true;
	const articles = await getCollection('blog');
	const posts = await getCollection('posts');

	const allContent: Result[] = [
		...articles.map((a) => ({
			title: a.data.title,
			description: a.data.description,
			url: `/article/${a.id}/`,
			pubDate: a.data.pubDate,
			type: 'Article' as const,
		})),
		...posts.map((p) => ({
			title: p.data.title,
			description: p.data.description,
			url: `/posts/${p.id}/`,
			pubDate: p.data.pubDate,
			type: 'Post' as const,
		})),
	];

	results = allContent
		.filter(
			(entry) =>
				entry.title.toLowerCase().includes(queryLower) ||
				entry.description.toLowerCase().includes(queryLower)
		)
		.sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={query ? `Search: "${query}" — Low Hanging Data` : 'Search — Low Hanging Data'}
			description="Search articles and posts on Low Hanging Data."
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>Search</h1>

			<form class="search-form" action="/search" method="get" role="search">
				<div class="input-wrap">
					<input
						type="search"
						name="q"
						value={query}
						placeholder="Search articles and posts…"
						aria-label="Search site"
						autofocus
					/>
					<button type="submit" aria-label="Search">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
						</svg>
					</button>
				</div>
			</form>

			{searched && (
				<div class="results">
					{results.length === 0 ? (
						<p class="no-results">No results for <strong>"{query}"</strong>.</p>
					) : (
						<>
							<p class="result-count">{results.length} result{results.length !== 1 ? 's' : ''} for <strong>"{query}"</strong></p>
							<ul class="result-list">
								{results.map((r) => (
									<li>
										<a href={r.url}>
											<div class="result-meta">
												<span class="result-type">{r.type}</span>
												<span class="result-date"><FormattedDate date={r.pubDate} /></span>
											</div>
											<h2 class="result-title">{r.title}</h2>
											<p class="result-desc">{r.description}</p>
										</a>
									</li>
								))}
							</ul>
						</>
					)}
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 3rem clamp(1rem, 5vw, 2rem);
	}

	h1 {
		margin-bottom: 1.5rem;
	}

	.search-form {
		margin-bottom: 2rem;
	}

	.input-wrap {
		display: flex;
		align-items: center;
		border: 1.5px solid var(--rule);
		border-radius: 8px;
		overflow: hidden;
		background: var(--paper);
		transition: border-color 0.18s ease, box-shadow 0.18s ease;
	}

	.input-wrap:focus-within {
		border-color: var(--accent);
		box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.15);
	}

	.input-wrap input {
		flex: 1;
		border: none;
		outline: none;
		background: transparent;
		padding: 0.65em 1em;
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--ink);
	}

	.input-wrap input::placeholder {
		color: var(--caption);
	}

	.input-wrap button {
		border: none;
		background: var(--accent);
		color: white;
		padding: 0 1em;
		height: 44px;
		cursor: pointer;
		display: flex;
		align-items: center;
		transition: background 0.18s ease;
	}

	.input-wrap button:hover {
		background: var(--accent-dark);
	}

	.result-count {
		color: var(--caption);
		font-size: 0.9rem;
		margin-bottom: 1.25rem;
	}

	.no-results {
		color: var(--caption);
	}

	.result-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.result-list li a {
		display: block;
		text-decoration: none;
		padding: 1rem 1.25rem;
		border: 1px solid var(--rule);
		border-radius: 8px;
		background: var(--paper);
		transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
	}

	.result-list li a:hover {
		border-color: var(--accent);
		box-shadow: var(--box-shadow);
		transform: translateY(-1px);
		text-decoration: none;
	}

	.result-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.3rem;
	}

	.result-type {
		font-family: var(--font-mono);
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		background: var(--accent-muted);
		color: var(--accent-dark);
		padding: 0.15em 0.55em;
		border-radius: 4px;
	}

	.result-date {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--caption);
		letter-spacing: 0.05em;
	}

	.result-title {
		font-family: var(--font-display);
		font-size: 1.1rem;
		font-weight: 600;
		margin: 0 0 0.3rem;
		color: var(--ink);
		transition: color 0.15s ease;
	}

	.result-list li a:hover .result-title {
		color: var(--accent);
	}

	.result-desc {
		margin: 0;
		font-size: 0.88rem;
		color: var(--caption);
		line-height: 1.5;
	}
</style>
