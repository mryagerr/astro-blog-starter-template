---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getDifficultyLabel, getDifficultyClass } from '../utils/difficultyBadge';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, difficulty } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} type="article" pubDate={pubDate} updatedDate={updatedDate} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				max-width: 820px;
				margin: 2rem auto 0;
				padding: 0 1em;
				box-sizing: border-box;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 10px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 680px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1.5em 1em 3em;
				color: var(--ink);
			}
			.title {
				margin-bottom: 1.5em;
				padding: 1.5em 0 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				font-family: var(--font-display);
				font-size: clamp(1.8rem, 4vw, 2.8rem);
				font-weight: 700;
				letter-spacing: -0.025em;
				line-height: 1.15;
				margin: 0 0 0.5em 0;
			}
			.article-character {
				display: block;
				margin: 0 auto 0.75em;
			}
			.date {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 0.75em;
				color: var(--caption);
			}
			.last-updated-on {
				font-style: italic;
				font-family: var(--font-body);
				letter-spacing: 0;
				text-transform: none;
				font-size: 0.85rem;
				margin-top: 0.25em;
			}
			.difficulty-badge {
				display: inline-block;
				margin: 0.5em 0 0;
				padding: 0.2em 0.75em;
				border-radius: 999px;
				font-size: 0.78rem;
				font-weight: 600;
				font-family: var(--font-mono);
				letter-spacing: 0.02em;
			}
			.difficulty-low  { background: #dcfce7; color: #166534; }
			.difficulty-high { background: #fef9c3; color: #854d0e; }
			.share-bar {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				margin: 1.25rem 0 0.25rem;
				justify-content: center;
				flex-wrap: wrap;
			}
			.share-label {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--caption);
			}
			.share-link {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.3em 0.75em;
				border-radius: 999px;
				font-size: 0.78rem;
				font-weight: 600;
				font-family: var(--font-mono);
				text-decoration: none;
				border: 1.5px solid currentColor;
				transition: opacity 0.15s;
			}
			.share-link:hover { opacity: 0.72; }
			.share-twitter { color: #0f1419; }
			.share-linkedin { color: #0a66c2; }
			@media (prefers-color-scheme: dark) {
				.share-twitter { color: #e7e9ea; }
			}

			@media (max-width: 480px) {
				.prose {
					max-width: calc(100% - 1em);
					padding: 1em 0.75em 2em;
				}
				.hero-image {
					margin: 1rem auto 0;
					padding: 0 0.5em;
				}
			}
		</style>
	</head>

	<body>
		<div id="scroll-progress" aria-hidden="true" style="position:fixed;top:0;left:0;height:3px;width:0%;background:var(--accent);z-index:9999;pointer-events:none;"></div>
		<script>
			const bar = document.getElementById('scroll-progress') as HTMLElement;
			function updateProgress() {
				const scrolled = window.scrollY;
				const max = document.documentElement.scrollHeight - window.innerHeight;
				bar.style.width = max > 0 ? (scrolled / max * 100) + '%' : '0%';
			}
			window.addEventListener('scroll', updateProgress, { passive: true });
		</script>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt="" loading="eager" decoding="async" sizes="(max-width: 820px) calc(100vw - 2em), 820px" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<svg class="article-character" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 90" width="64" height="72" aria-hidden="true">
						<!-- Head -->
						<circle cx="40" cy="18" r="10" fill="#fcd34d" stroke="#92400e" stroke-width="1.5"/>
						<!-- Eyes -->
						<circle cx="36.5" cy="16" r="1.4" fill="#1e293b"/>
						<circle cx="43.5" cy="16" r="1.4" fill="#1e293b"/>
						<!-- Smile (open mouth munching) -->
						<path d="M36 21 Q40 25 44 21" fill="none" stroke="#1e293b" stroke-width="1.4" stroke-linecap="round"/>
						<!-- Body -->
						<rect x="33" y="28" width="14" height="22" rx="4" fill="#38bdf8"/>
						<!-- Left arm (relaxed, down) -->
						<line x1="33" y1="32" x2="22" y2="44" stroke="#fcd34d" stroke-width="3.5" stroke-linecap="round"/>
						<!-- Right arm (raised, holding apple to mouth) -->
						<line x1="47" y1="30" x2="56" y2="20" stroke="#fcd34d" stroke-width="3.5" stroke-linecap="round"/>
						<!-- Apple held at mouth -->
						<circle cx="61" cy="17" r="7" fill="#f43f5e"/>
						<circle cx="58.5" cy="14" r="2" fill="#ffffff" opacity="0.35"/>
						<line x1="61" y1="10" x2="61" y2="7" stroke="#a16207" stroke-width="1.6" stroke-linecap="round"/>
						<ellipse cx="65" cy="8" rx="3.5" ry="1.6" fill="#22c55e" transform="rotate(20 65 8)"/>
						<!-- Bite mark -->
						<path d="M54 17 Q56 13 60 14" fill="#fff8" stroke="none"/>
						<!-- Left leg -->
						<line x1="37" y1="50" x2="33" y2="68" stroke="#fcd34d" stroke-width="3.5" stroke-linecap="round"/>
						<!-- Right leg -->
						<line x1="43" y1="50" x2="47" y2="68" stroke="#fcd34d" stroke-width="3.5" stroke-linecap="round"/>
						<!-- Left foot -->
						<ellipse cx="31" cy="70" rx="5" ry="2.5" fill="#1e293b"/>
						<!-- Right foot -->
						<ellipse cx="49" cy="70" rx="5" ry="2.5" fill="#1e293b"/>
					</svg>
					<h1>{title}</h1>
						{difficulty && (
							<p class={getDifficultyClass(difficulty)}>
								{getDifficultyLabel(difficulty)}
							</p>
						)}
						<hr />
					<div class="share-bar">
						<span class="share-label">Share:</span>
						<a
							href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`}
							target="_blank"
							rel="noopener noreferrer"
							class="share-link share-twitter"
							aria-label="Share on X (Twitter)"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.729-8.835L1.254 2.25H8.08l4.254 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
							</svg>
							X
						</a>
						<a
							href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
							target="_blank"
							rel="noopener noreferrer"
							class="share-link share-linkedin"
							aria-label="Share on LinkedIn"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
							</svg>
							LinkedIn
						</a>
					</div>
				</div>
				<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
