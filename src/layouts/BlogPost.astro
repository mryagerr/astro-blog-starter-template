---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getDifficultyLabel, getDifficultyClass } from '../utils/difficultyBadge';

type RelatedPost = {
	id: string;
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: string;
	href: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime?: number;
	wordCount?: number;
	headings?: MarkdownHeading[];
	relatedPosts?: RelatedPost[];
	breadcrumb?: { href: string; label: string };
};

const { title, description, pubDate, updatedDate, heroImage, difficulty, readingTime, wordCount, headings, relatedPosts, breadcrumb } = Astro.props;

const tocHeadings = (headings ?? []).filter((h) => h.depth <= 3);
const showToc = tocHeadings.length >= 3;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} type="article" pubDate={pubDate} updatedDate={updatedDate} wordCount={wordCount} breadcrumb={breadcrumb} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}

			/* ─── Breadcrumb ──────────────────────────────────────── */
			.breadcrumb {
				max-width: 820px;
				margin: 1.25rem auto 0;
				padding: 0 1em;
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				color: var(--caption);
				display: flex;
				align-items: center;
				gap: 0.4rem;
				flex-wrap: wrap;
			}
			.breadcrumb a {
				color: var(--caption);
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.breadcrumb-sep {
				color: var(--rule);
			}
			.breadcrumb-current {
				color: var(--ink);
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
				max-width: 280px;
			}

			/* ─── Hero image ──────────────────────────────────────── */
			.hero-image {
				width: 100%;
				max-width: 820px;
				margin: 1.25rem auto 0;
				padding: 0 1em;
				box-sizing: border-box;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 10px;
				box-shadow: var(--box-shadow);
			}

			/* ─── Article layout (prose + optional ToC sidebar) ──── */
			.article-layout {
				display: flex;
				align-items: flex-start;
				gap: 2.5rem;
				max-width: 960px;
				margin: 0 auto;
				padding: 0 1em;
			}

			/* ─── Prose ───────────────────────────────────────────── */
			.prose {
				flex: 1;
				min-width: 0;
				max-width: 680px;
				margin: 0 auto;
				padding: 1.5em 0 3em;
				color: var(--ink);
			}

			/* When ToC is present, prose doesn't auto-center */
			.article-layout.has-toc .prose {
				margin: 0;
			}

			.title {
				margin-bottom: 1.5em;
				padding: 1.5em 0 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				font-family: var(--font-display);
				font-size: clamp(1.8rem, 4vw, 2.8rem);
				font-weight: 700;
				letter-spacing: -0.025em;
				line-height: 1.15;
				margin: 0 0 0.5em 0;
			}
			.article-character {
				display: block;
				margin: 0 auto 0.75em;
			}
			.meta-line {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 0.75em;
				color: var(--caption);
				display: flex;
				align-items: center;
				justify-content: center;
				flex-wrap: wrap;
				gap: 0 0.5rem;
			}
			.reading-time {
				color: var(--caption);
			}
			.last-updated-on {
				font-style: italic;
				font-family: var(--font-body);
				letter-spacing: 0;
				text-transform: none;
				font-size: 0.85rem;
				margin-top: 0.25em;
				width: 100%;
				text-align: center;
			}
			.difficulty-badge {
				display: inline-block;
				margin: 0.5em 0 0;
				padding: 0.2em 0.75em;
				border-radius: 999px;
				font-size: 0.78rem;
				font-weight: 600;
				font-family: var(--font-mono);
				letter-spacing: 0.02em;
			}
			.difficulty-low  { background: #dcfce7; color: #166534; }
			.difficulty-high { background: #fef9c3; color: #854d0e; }

			/* ─── Share bar ───────────────────────────────────────── */
			.share-bar {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				margin: 1.25rem 0 0.25rem;
				justify-content: center;
				flex-wrap: wrap;
			}
			.share-label {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--caption);
			}
			.share-link {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.3em 0.75em;
				border-radius: 999px;
				font-size: 0.78rem;
				font-weight: 600;
				font-family: var(--font-mono);
				text-decoration: none;
				border: 1.5px solid currentColor;
				transition: opacity 0.15s;
			}
			.share-link:hover { opacity: 0.72; }
			.share-twitter { color: #0f1419; }
			.share-linkedin { color: #0a66c2; }
			@media (prefers-color-scheme: dark) {
				.share-twitter { color: #e7e9ea; }
			}

			/* ─── Mobile ToC (collapsible) ───────────────────────── */
			.toc-mobile {
				display: none;
				border: 1px solid var(--rule);
				border-radius: 6px;
				padding: 0.75rem 1rem;
				margin-bottom: 1.5rem;
				font-size: 0.9rem;
			}
			.toc-mobile summary {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--caption);
				cursor: pointer;
				list-style: none;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.toc-mobile summary::after {
				content: '▾';
				transition: transform 0.2s;
			}
			.toc-mobile[open] summary::after {
				transform: rotate(-180deg);
			}
			.toc-mobile ol {
				margin: 0.75rem 0 0;
				padding: 0 0 0 1rem;
				list-style: none;
			}
			.toc-mobile li { margin: 0.3rem 0; }
			.toc-mobile a {
				color: var(--caption);
				text-decoration: none;
				font-size: 0.88rem;
			}
			.toc-mobile a:hover { color: var(--accent); }
			.toc-mobile .toc-h3 { padding-left: 1rem; font-size: 0.82rem; }

			/* ─── Desktop ToC sidebar ─────────────────────────────── */
			.toc-sidebar {
				width: 200px;
				flex-shrink: 0;
				position: sticky;
				top: 80px;
				align-self: flex-start;
				padding-top: 3rem;
			}
			.toc {
				border-left: 2px solid var(--rule);
				padding-left: 1rem;
			}
			.toc-heading {
				font-family: var(--font-mono);
				font-size: 0.68rem;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--caption);
				margin: 0 0 0.75rem;
			}
			.toc ol {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.toc li { margin: 0.35rem 0; }
			.toc a {
				font-size: 0.82rem;
				color: var(--caption);
				text-decoration: none;
				line-height: 1.4;
				display: block;
				transition: color 0.15s;
			}
			.toc a:hover,
			.toc a.toc-active {
				color: var(--accent);
			}
			.toc .toc-h3 {
				padding-left: 0.85rem;
				font-size: 0.78rem;
			}

			/* ─── Related articles ───────────────────────────────── */
			.related-articles {
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid var(--rule);
			}
			.related-title {
				font-family: var(--font-display);
				font-size: 1.1rem;
				font-weight: 600;
				margin: 0 0 1.25rem;
				color: var(--ink);
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.related-card a {
				display: block;
				text-decoration: none;
				border: 1px solid var(--rule);
				border-radius: 8px;
				overflow: hidden;
				background: var(--paper);
				transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
			}
			.related-card a:hover {
				box-shadow: var(--box-shadow);
				border-color: var(--accent-muted);
				transform: translateY(-2px);
			}
			.related-card img {
				width: 100%;
				height: 100px;
				object-fit: cover;
				display: block;
			}
			.related-body {
				padding: 0.6rem 0.75rem 0.75rem;
			}
			.related-date {
				font-family: var(--font-mono);
				font-size: 0.68rem;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				color: var(--caption);
				margin: 0 0 0.2rem;
			}
			.related-card-title {
				margin: 0;
				font-family: var(--font-display);
				font-size: 0.88rem;
				font-weight: 600;
				line-height: 1.3;
				color: var(--ink);
				transition: color 0.15s;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.related-card a:hover .related-card-title {
				color: var(--accent);
			}

			/* ─── Newsletter CTA ─────────────────────────────────── */
			.newsletter-cta {
				margin-top: 2.5rem;
				padding: 1.75rem 1.5rem;
				background: rgba(8, 145, 178, 0.06);
				border: 1px solid var(--accent-muted);
				border-radius: 10px;
				text-align: center;
			}
			.newsletter-heading {
				font-family: var(--font-display);
				font-size: 1.1rem;
				font-weight: 700;
				margin: 0 0 0.4rem;
				color: var(--ink);
			}
			.newsletter-sub {
				font-size: 0.9rem;
				color: var(--caption);
				margin: 0 0 1.1rem;
			}
			.newsletter-form {
				display: flex;
				gap: 0.5rem;
				max-width: 380px;
				margin: 0 auto;
				flex-wrap: wrap;
				justify-content: center;
			}
			.newsletter-form input[type="email"] {
				flex: 1;
				min-width: 180px;
				padding: 0.5em 0.9em;
				border: 1.5px solid var(--rule);
				border-radius: 6px;
				font-family: var(--font-body);
				font-size: 0.9rem;
				background: var(--paper);
				color: var(--ink);
				outline: none;
				transition: border-color 0.18s;
			}
			.newsletter-form input[type="email"]:focus {
				border-color: var(--accent);
				box-shadow: 0 0 0 2px rgba(8, 145, 178, 0.18);
			}
			.newsletter-form button {
				padding: 0.5em 1.1em;
				background: var(--accent);
				color: #fff;
				border: none;
				border-radius: 6px;
				font-family: var(--font-mono);
				font-size: 0.85rem;
				font-weight: 600;
				cursor: pointer;
				transition: background 0.18s;
				white-space: nowrap;
			}
			.newsletter-form button:hover {
				background: var(--accent-dark);
			}
			.newsletter-confirm {
				font-size: 0.88rem;
				color: var(--accent-dark);
				margin: 0.75rem 0 0;
			}

			/* ─── Responsive ──────────────────────────────────────── */
			@media (max-width: 900px) {
				.toc-sidebar { display: none; }
				.toc-mobile { display: block; }
				.article-layout.has-toc .prose { margin: 0 auto; }
				.related-grid { grid-template-columns: repeat(2, 1fr); }
			}

			@media (max-width: 600px) {
				.related-grid { grid-template-columns: 1fr; }
				.newsletter-cta { padding: 1.25rem 1rem; }
			}

			@media (max-width: 480px) {
				.prose {
					padding: 1em 0 2em;
				}
				.hero-image {
					margin: 0.75rem auto 0;
					padding: 0 0.5em;
				}
				.article-layout {
					padding: 0 0.75em;
				}
				.breadcrumb {
					padding: 0 0.75em;
				}
			}
		</style>
	</head>

	<body>
		<div id="scroll-progress" aria-hidden="true" style="position:fixed;top:0;left:0;height:3px;width:0%;background:var(--accent);z-index:9999;pointer-events:none;"></div>
		<script>
			const bar = document.getElementById('scroll-progress') as HTMLElement;
			function updateProgress() {
				const scrolled = window.scrollY;
				const max = document.documentElement.scrollHeight - window.innerHeight;
				bar.style.width = max > 0 ? (scrolled / max * 100) + '%' : '0%';
			}
			window.addEventListener('scroll', updateProgress, { passive: true });
		</script>
		<Header />
		<main id="main-content">
			<article>
				<!-- Breadcrumb -->
				{breadcrumb && (
					<nav class="breadcrumb" aria-label="Breadcrumb">
						<a href="/">Home</a>
						<span class="breadcrumb-sep" aria-hidden="true">›</span>
						<a href={breadcrumb.href}>{breadcrumb.label}</a>
						<span class="breadcrumb-sep" aria-hidden="true">›</span>
						<span class="breadcrumb-current" aria-current="page">{title}</span>
					</nav>
				)}

				<!-- Hero image -->
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt={title} loading="eager" decoding="async" sizes="(max-width: 820px) calc(100vw - 2em), 820px" />}
				</div>

				<!-- Content layout -->
				<div class={`article-layout${showToc ? ' has-toc' : ''}`}>

					<!-- Main prose -->
					<div class="prose">

						<!-- Mobile ToC (collapsible, shown only on small screens via CSS) -->
						{showToc && (
							<details class="toc-mobile">
								<summary>Contents</summary>
								<nav aria-label="Table of contents">
									<ol>
										{tocHeadings.map((h) => (
											<li class={`toc-h${h.depth}`}>
												<a href={`#${h.slug}`}>{h.text}</a>
											</li>
										))}
									</ol>
								</nav>
							</details>
						)}

						<div class="title">
							<div class="meta-line">
								<FormattedDate date={pubDate} />
								{readingTime && <span class="reading-time">· {readingTime} min read</span>}
								{updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)}
							</div>
							<svg class="article-character" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 90" width="64" height="72" aria-hidden="true">
							<!-- Head -->
							<circle cx="40" cy="18" r="10" fill="#fcd34d" stroke="#92400e" stroke-width="1.5"/>
							<!-- Eyes -->
							<circle cx="36.5" cy="16" r="1.4" fill="#1e293b"/>
							<circle cx="43.5" cy="16" r="1.4" fill="#1e293b"/>
							<!-- Smile (open mouth munching) -->
							<path d="M36 21 Q40 25 44 21" fill="none" stroke="#1e293b" stroke-width="1.4" stroke-linecap="round"/>
							<!-- Body -->
							<rect x="33" y="28" width="14" height="22" rx="4" fill="#38bdf8"/>
							<!-- Left arm (relaxed, down) -->
							<line x1="33" y1="32" x2="22" y2="44" stroke="#fcd34d" stroke-width="3.5" stroke-linecap="round"/>
							<!-- Right arm (raised, holding apple to mouth) -->
							<line x1="47" y1="30" x2="56" y2="20" stroke="#fcd34d" stroke-width="3.5" stroke-linecap="round"/>
							<!-- Apple held at mouth -->
							<circle cx="61" cy="17" r="7" fill="#f43f5e"/>
							<circle cx="58.5" cy="14" r="2" fill="#ffffff" opacity="0.35"/>
							<line x1="61" y1="10" x2="61" y2="7" stroke="#a16207" stroke-width="1.6" stroke-linecap="round"/>
							<ellipse cx="65" cy="8" rx="3.5" ry="1.6" fill="#22c55e" transform="rotate(20 65 8)"/>
							<!-- Bite mark -->
							<path d="M54 17 Q56 13 60 14" fill="#fff8" stroke="none"/>
							<!-- Left leg -->
							<line x1="37" y1="50" x2="33" y2="68" stroke="#fcd34d" stroke-width="3.5" stroke-linecap="round"/>
							<!-- Right leg -->
							<line x1="43" y1="50" x2="47" y2="68" stroke="#fcd34d" stroke-width="3.5" stroke-linecap="round"/>
							<!-- Left foot -->
							<ellipse cx="31" cy="70" rx="5" ry="2.5" fill="#1e293b"/>
							<!-- Right foot -->
							<ellipse cx="49" cy="70" rx="5" ry="2.5" fill="#1e293b"/>
						</svg>
						<h1>{title}</h1>
							{difficulty && (
								<p class={getDifficultyClass(difficulty)}>
									{getDifficultyLabel(difficulty)}
								</p>
							)}
							<hr />
						<div class="share-bar">
							<span class="share-label">Share:</span>
							<a
								href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`}
								target="_blank"
								rel="noopener noreferrer"
								class="share-link share-twitter"
								aria-label="Share on X (Twitter)"
							>
								<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.729-8.835L1.254 2.25H8.08l4.254 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
								</svg>
								X
							</a>
							<a
								href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
								target="_blank"
								rel="noopener noreferrer"
								class="share-link share-linkedin"
								aria-label="Share on LinkedIn"
							>
								<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
								</svg>
								LinkedIn
							</a>
						</div>
					</div>

					<slot />

					<!-- Related articles -->
					{relatedPosts && relatedPosts.length > 0 && (
						<div class="related-articles">
							<h2 class="related-title">More Articles</h2>
							<ul class="related-grid">
								{relatedPosts.map((rp) => (
									<li class="related-card">
										<a href={rp.href} aria-label={rp.title}>
											<img
												src={rp.heroImage ?? '/blog-placeholder-1.png'}
												alt={rp.title}
												loading="lazy"
												decoding="async"
											/>
											<div class="related-body">
												<p class="related-date"><FormattedDate date={rp.pubDate} /></p>
												<p class="related-card-title">{rp.title}</p>
											</div>
										</a>
									</li>
								))}
							</ul>
						</div>
					)}

					<!-- Newsletter CTA -->
					<div class="newsletter-cta">
						<p class="newsletter-heading">Get new articles by email</p>
						<p class="newsletter-sub">Practical guides on data workflows, delivered when published. No spam.</p>
						<form class="newsletter-form" id="newsletter-form">
							<input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
							<button type="submit">Subscribe →</button>
						</form>
						<p class="newsletter-confirm" id="newsletter-confirm" hidden>
							Thanks! Opening your email client so you can confirm your subscription.
						</p>
					</div>
					<script>
						const form = document.getElementById('newsletter-form') as HTMLFormElement;
						const confirm = document.getElementById('newsletter-confirm') as HTMLElement;
						form?.addEventListener('submit', (e) => {
							e.preventDefault();
							const email = new FormData(form).get('email') as string;
							if (email) {
								const subject = encodeURIComponent('Subscribe to Low Hanging Data');
								const body = encodeURIComponent(`Hi,\n\nPlease add ${email} to the Low Hanging Data mailing list.\n\nThanks!`);
								window.location.href = `mailto:admin@lowhangingdata.com?subject=${subject}&body=${body}`;
								form.hidden = true;
								confirm.hidden = false;
							}
						});
					</script>

					</div><!-- end .prose -->

					<!-- Desktop ToC sidebar -->
					{showToc && (
						<aside class="toc-sidebar" aria-label="Table of contents">
							<nav class="toc">
								<p class="toc-heading">Contents</p>
								<ol>
									{tocHeadings.map((h) => (
										<li class={`toc-h${h.depth}`}>
											<a href={`#${h.slug}`}>{h.text}</a>
										</li>
									))}
								</ol>
							</nav>
						</aside>
					)}

				</div><!-- end .article-layout -->
			</article>
		</main>
		<Footer />

		{showToc && (
			<script>
				// Highlight current ToC section as user scrolls
				const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc a'));
				if (tocLinks.length) {
					const headingIds = tocLinks.map((a) => new URL(a.href).hash.slice(1));
					const headingEls = headingIds.map((id) => document.getElementById(id)).filter((el): el is HTMLElement => el !== null);

					function updateToc() {
						let activeIdx = 0;
						for (let i = 0; i < headingEls.length; i++) {
							if (headingEls[i].getBoundingClientRect().top <= 90) activeIdx = i;
						}
						tocLinks.forEach((a, i) => a.classList.toggle('toc-active', i === activeIdx));
					}

					window.addEventListener('scroll', updateToc, { passive: true });
					updateToc();
				}
			</script>
		)}
	</body>
</html>
