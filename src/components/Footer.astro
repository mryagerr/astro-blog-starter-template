---
import { getCurrentYear } from '../utils/formatDate';
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<a href="/" class="footer-wordmark">Low Hanging Data</a>
			<p class="footer-tagline">Data analysis should be concise, transparent, and focused on the low hanging fruit first.</p>
		</div>
		<nav class="footer-nav" aria-label="Footer navigation">
			<span class="footer-nav-label">Explore</span>
			<a href="/">Home</a>
			<a href="/article">Articles</a>
			<a href="/about">About</a>
			<a href="/contact">Contact</a>
			<a href="/privacy">Privacy</a>
			<a href="/terms">Terms</a>
			<a href="/rss.xml">RSS Feed</a>
		</nav>
	</div>
	<div class="footer-bottom">
		<span>&copy; {getCurrentYear()} Low Hanging Data</span>
		<span class="footer-sep">·</span>
		<span>Concise. Transparent. Low Hanging Fruit First.</span>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--rule);
		background: var(--paper);
		padding: 0 clamp(1.5rem, 5vw, 4rem);
	}

	.footer-inner {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 2.5rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 3rem 0 2rem;
	}

	.footer-wordmark {
		display: block;
		font-family: var(--font-display);
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--ink);
		text-decoration: none;
		margin-bottom: 0.6rem;
		letter-spacing: -0.01em;
	}

	.footer-wordmark:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.footer-tagline {
		font-size: 0.84rem;
		color: var(--caption);
		line-height: 1.55;
		margin: 0;
		max-width: 280px;
	}

	.footer-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.footer-nav-label {
		font-family: var(--font-mono);
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--caption);
		margin-bottom: 0.25rem;
	}

	.footer-nav a {
		font-size: 0.88rem;
		color: var(--caption);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.footer-nav a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.footer-bottom {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		flex-wrap: wrap;
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.25rem 0 2.5rem;
		border-top: 1px solid var(--rule);
		font-size: 0.8rem;
		color: var(--caption);
		font-family: var(--font-mono);
	}

	.footer-sep {
		color: var(--rule);
	}

	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.footer-brand {
			grid-column: unset;
		}
		.footer-bottom {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.25rem;
		}
		.footer-sep { display: none; }
	}

	@media (max-width: 480px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			padding: 2rem 0 1.5rem;
		}
		.footer-brand { grid-column: unset; }
		footer { padding: 0 1rem; }
	}
</style>
