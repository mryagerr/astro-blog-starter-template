---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" class="wordmark" aria-label="Low Hanging Data — home">{SITE_TITLE}</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/article">Articles</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 clamp(1rem, 5vw, 3rem);
		background: rgba(247, 245, 240, 0.95);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--rule);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 60px;
		gap: 1.5rem;
	}

	.wordmark {
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--ink);
		text-decoration: none;
		letter-spacing: -0.01em;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.wordmark:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	/* Override HeaderLink anchor styles */
	.internal-links :global(a) {
		font-family: var(--font-body);
		font-size: 0.9rem;
		font-variant: small-caps;
		letter-spacing: 0.04em;
		color: var(--caption);
		text-decoration: none;
		padding: 0.35em 0.65em;
		position: relative;
		transition: color 0.18s ease;
	}

	.internal-links :global(a::after) {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0.65em;
		right: 0.65em;
		height: 2px;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.18s ease;
	}

	.internal-links :global(a:hover) {
		color: var(--ink);
		text-decoration: none;
	}

	.internal-links :global(a:hover::after),
	.internal-links :global(a.active::after) {
		transform: scaleX(1);
	}

	.internal-links :global(a.active) {
		color: var(--ink);
		font-weight: 600;
	}

	@media (max-width: 720px) {
		.wordmark { font-size: 1rem; }

		/* Larger touch targets on mobile */
		.internal-links :global(a) {
			padding: 0.5em 0.6em;
			min-height: 44px;
			display: flex;
			align-items: center;
		}
	}

	@media (max-width: 400px) {
		.wordmark { font-size: 0.9rem; }

		.internal-links :global(a) {
			font-size: 0.8rem;
			padding: 0.5em 0.4em;
		}

		nav { gap: 0.5rem; }
	}
</style>
