---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" class="wordmark" aria-label="Low Hanging Data — home">{SITE_TITLE}</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/article">Articles</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<form class="search-form" action="/search" method="get" role="search">
			<div class="search-wrap">
				<input
					type="search"
					name="q"
					placeholder="Search…"
					aria-label="Search site"
					class="search-input"
				/>
				<button type="submit" class="search-btn" aria-label="Submit search">
					<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
					</svg>
				</button>
			</div>
		</form>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 clamp(1rem, 5vw, 3rem);
		background: var(--header-bg);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--rule);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 60px;
		gap: 1.5rem;
	}

	.wordmark {
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--ink);
		text-decoration: none;
		letter-spacing: -0.01em;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.wordmark:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	/* Override HeaderLink anchor styles */
	.internal-links :global(a) {
		font-family: var(--font-body);
		font-size: 0.9rem;
		font-variant: small-caps;
		letter-spacing: 0.04em;
		color: var(--caption);
		text-decoration: none;
		padding: 0.35em 0.65em;
		position: relative;
		transition: color 0.18s ease;
	}

	.internal-links :global(a::after) {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0.65em;
		right: 0.65em;
		height: 2px;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.18s ease;
	}

	.internal-links :global(a:hover) {
		color: var(--ink);
		text-decoration: none;
	}

	.internal-links :global(a:hover::after),
	.internal-links :global(a.active::after) {
		transform: scaleX(1);
	}

	.internal-links :global(a.active) {
		color: var(--ink);
		font-weight: 600;
	}

	/* ─── Search ──────────────────────────────────────────────────── */

	.search-form {
		flex-shrink: 0;
	}

	.search-wrap {
		display: flex;
		align-items: center;
		border: 1.5px solid var(--rule);
		border-radius: 6px;
		overflow: hidden;
		background: transparent;
		transition: border-color 0.18s ease, box-shadow 0.18s ease;
		height: 34px;
	}

	.search-wrap:focus-within {
		border-color: var(--accent);
		box-shadow: 0 0 0 2px rgba(8, 145, 178, 0.18);
	}

	.search-input {
		border: none;
		outline: none;
		background: transparent;
		padding: 0 0.6em 0 0.8em;
		font-family: var(--font-body);
		font-size: 0.88rem;
		color: var(--ink);
		width: 140px;
		transition: width 0.25s ease;
	}

	.search-input::placeholder {
		color: var(--caption);
	}

	.search-input:focus {
		width: 200px;
	}

	.search-btn {
		border: none;
		background: transparent;
		color: var(--caption);
		padding: 0 0.6em;
		height: 100%;
		cursor: pointer;
		display: flex;
		align-items: center;
		transition: color 0.18s ease, background 0.18s ease;
	}

	.search-btn:hover {
		color: var(--accent);
		background: rgba(8, 145, 178, 0.08);
	}

	@media (max-width: 720px) {
		.wordmark { font-size: 1rem; }

		.search-input { width: 80px; }
		.search-input:focus { width: 120px; }

		/* Larger touch targets on mobile */
		.internal-links :global(a) {
			padding: 0.5em 0.6em;
			min-height: 44px;
			display: flex;
			align-items: center;
		}
	}

	@media (max-width: 400px) {
		.wordmark { font-size: 0.9rem; }

		.internal-links :global(a) {
			font-size: 0.8rem;
			padding: 0.5em 0.4em;
		}

		.search-input { width: 55px; }
		.search-input:focus { width: 85px; }

		nav { gap: 0.5rem; }
	}
</style>
